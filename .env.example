VITE_API_BASE_URL=http://127.0.0.1:8000

# Optional. If omitted, it is derived from VITE_API_BASE_URL.
# VITE_WS_BASE_URL=ws://127.0.0.1:8000

# Optional. Needed when the app is served from a subpath like /my-project
# VITE_APP_BASE_PATH=/my-project

# Optional. Use hash mode for static hosts without SPA rewrites, such as GitHub Pages.
# VITE_ROUTER_MODE=hash

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_DATABASE_URL=
